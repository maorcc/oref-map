#!/bin/sh
# Start local dev server at http://localhost:8788 (binds to 0.0.0.0 — also accessible via http://<your-ip>:8788).

POLYGONS=web/locations_polygons.json
if [ ! -f "$POLYGONS" ]; then
  echo "WARNING: $POLYGONS not found. Run ./build in oref-polygons first, or production endpoint will be used."
fi

npx wrangler pages dev web/ --ip 0.0.0.0 "$@"
